{
    "name": "cinemaline-root",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build:client": "npm run build --prefix client",
        "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
        "dev:server": "npm --prefix server run dev",
        "dev:client": "npm --prefix client run dev",
        "start": "node server/index.js"
    },
    "description": "> \"As a movie enthusiast, I want a seamless and cinematic way to book my experience, so that I can spend less time waiting and more time enjoying the show.\"",
    "main": "index.js",
    "devDependencies": {
        "concurrently": "^8.2.0"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "firebase": "^12.14.0",
        "lucide-react": "^1.17.0"
    }
}
